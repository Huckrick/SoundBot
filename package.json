{
  "name": "soundbot",
  "version": "0.1.2",
  "description": "SoundBot - AI 音效管理器桌面版 (PyInstaller 一体化版本)",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "python scripts/build.py",
    "build:mac": "python scripts/build.py --platform macos",
    "build:win": "python scripts/build.py --platform windows",
    "build:linux": "python scripts/build.py --platform linux",
    "build:all": "python scripts/build.py --platform all",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rm -rf dist backend/dist backend/build"
  },
  "keywords": [
    "electron",
    "audio",
    "sound",
    "manager",
    "ai",
    "semantic-search",
    "clap",
    "pyinstaller"
  ],
  "author": "Nagisa_Huckrick (胡杨) <Nagisa_Huckrick@yeah.net>",
  "license": "GPL-3.0",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.soundbot.app",
    "productName": "SoundBot",
    "copyright": "Copyright © 2026 Nagisa_Huckrick (胡杨)",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "tailwindcss.js",
      "lucide.min.js",
      "wavesurfer.min.js",
      "wavesurfer.regions.min.js",
      "assets/**/*",
      "config/**/*",
      "!backend/**",
      "!scripts/**",
      "!**/*.pyc",
      "!**/__pycache__",
      "!**/*.spec",
      "!backend/dist",
      "!backend/build",
      "!dist-electron",
      "!**/venv",
      "!**/models",
      "!**/.git"
    ],

    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "license": "LICENSE"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "extraResources": [
      {
        "from": "dist/backend/soundbot-backend",
        "to": "backend/soundbot-backend"
      }
    ],
    "publish": null
  }
}
